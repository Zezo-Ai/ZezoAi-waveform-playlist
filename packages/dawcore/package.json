{
  "name": "@dawcore/components",
  "version": "0.0.25",
  "description": "Web Components for multi-track audio editing \u2014 framework-agnostic",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": true,
  "scripts": {
    "build": "pnpm typecheck && tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "daw",
    "web-components",
    "audio",
    "webaudio",
    "multitrack",
    "audio-editor",
    "lit"
  ],
  "author": "Naomi Aro",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@dawcore/spectrogram": "workspace:*",
    "lit": "^3.3.3",
    "waveform-data": "^4.5.2"
  },
  "peerDependencies": {
    "@dawcore/faust": ">=0.0.1",
    "@dawcore/midi": ">=0.0.1",
    "@dawcore/transport": ">=0.0.13",
    "@dawcore/wam": ">=0.0.1",
    "@waveform-playlist/core": ">=12.0.0",
    "@waveform-playlist/engine": ">=13.5.0",
    "@waveform-playlist/worklets": ">=12.0.0"
  },
  "peerDependenciesMeta": {
    "@dawcore/faust": {
      "optional": true
    },
    "@dawcore/midi": {
      "optional": true
    },
    "@dawcore/transport": {
      "optional": true
    },
    "@dawcore/wam": {
      "optional": true
    },
    "@waveform-playlist/worklets": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dawcore/faust": "workspace:*",
    "@dawcore/midi": "workspace:*",
    "@dawcore/transport": "workspace:*",
    "@dawcore/wam": "workspace:*",
    "@waveform-playlist/core": "workspace:*",
    "@waveform-playlist/engine": "workspace:*",
    "@waveform-playlist/worklets": "workspace:*",
    "happy-dom": "^20.10.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
