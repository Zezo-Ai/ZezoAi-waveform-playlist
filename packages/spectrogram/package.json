{
  "name": "@waveform-playlist/spectrogram",
  "version": "13.0.2",
  "description": "React Provider + UI for spectrograms — wraps @dawcore/spectrogram",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
